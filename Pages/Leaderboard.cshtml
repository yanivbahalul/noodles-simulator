@page
@model NoodlesSimulator.Pages.LeaderboardModel
@{
    ViewData["Title"] = "טבלת מובילים";
}

<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — טבלת מובילים</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo/noodles-logo-transparent.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/logo/noodles-logo-transparent.png">
    <link rel="apple-touch-icon" sizes="192x192" href="/logo/noodles-logo-transparent.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#222222">
</head>

<!-- background -->
<img src="/assets/background.gif" alt="רקע" class="background-gif" />

<partial name="Shared/_TopBar" />
<partial name="Shared/_LogoHeader" />

<!-- leaderoard -->
<div class="quiz-container leaderboard-container">
    <h2 class="leaderboard-title">🏆 טבלת המובילים</h2>
    <div id="last-update" class="leaderboard-last-update">(מתעדכן...)</div>

    <table id="leaderboard-table" class="leaderboard-table">
        <thead>
            <tr class="leaderboard-header-row">
                <th class="leaderboard-cell-header">#</th>
                <th class="leaderboard-cell-header">שם משתמש</th>
                <th class="leaderboard-cell-header">תשובות נכונות</th>
            </tr>
        </thead>
        <tbody>
        @for (int i = 0; i < Model.SortedUsers.Count; i++)
        {
            var user = Model.SortedUsers[i];
            <tr class="leaderboard-data-row @(i % 2 == 0 ? "leaderboard-row-even" : "leaderboard-row-odd")">
                <td class="leaderboard-cell">@(@i + 1)</td>
                <td class="leaderboard-cell">
                    @{
                        var isOnline = user.LastSeen != null && user.LastSeen > DateTime.UtcNow.AddMinutes(-5);
                    }
                    @if (isOnline)
                    {
                        <strong class="leaderboard-online-user">@user.Username</strong>
                    }
                    else
                    {
                        @user.Username
                    }
                </td>
                <td class="leaderboard-cell">@user.CorrectAnswers</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<script src="/js/leaderboard-page.js"></script>

<partial name="Shared/_SiteFooter" />
