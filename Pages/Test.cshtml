@page
@model NoodlesSimulator.Pages.TestModel
@{
    ViewData["Title"] = "מצב מבחן";
}

<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — Test Mode</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo/noodles-logo-transparent.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/logo/noodles-logo-transparent.png">
    <link rel="apple-touch-icon" sizes="192x192" href="/logo/noodles-logo-transparent.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#222222">
    <meta name="robots" content="noindex">
}</head>

<img src="/assets/background.gif" alt="רקע" class="background-gif" />

<div class="top-bar">
    <div class="top-bar-inner">
        <div class="footer-icons">
            <a href="/Index" class="footer-icon" title="דף הבית">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9.5L12 3l9 6.5V21a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1V9.5z" />
                </svg>
            </a>
            <a href="/MyExams" class="footer-icon" title="המבחנים שלי">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="7" y1="9" x2="17" y2="9" />
                    <line x1="7" y1="13" x2="14" y2="13" />
                    <line x1="7" y1="17" x2="11" y2="17" />
                </svg>
            </a>
            <a href="/Leaderboard" class="footer-icon" title="טבלת מובילים">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 21h8" />
                    <path d="M12 17v4" />
                    <path d="M7 4h10v5a5 5 0 0 1-10 0V4z" />
                    <path d="M5 4h2" />
                    <path d="M17 4h2" />
                </svg>
            </a>
        </div>
        @if (ViewData["Token"] != null)
        {
            <form method="post" action="/Test?handler=EndTest" class="test-end-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@ViewData["Token"]" />
                <button type="submit" class="footer-icon confirm-end-test-btn" title="סיים מבחן">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <path d="M9 12h6" />
                        <path d="M12 9v6" />
                    </svg>
                </button>
            </form>
        }
    </div>
</div>

<div class="top-bar-spacer"></div>

<partial name="Shared/_LogoHeader" />

<div class="quiz-container test-quiz-container">

    <h2 class="test-title">מצב מבחן</h2>
    
    @if (TempData["ActiveTestAlert"] != null)
    {
        <div class="test-active-alert">
            <strong class="test-active-alert-text">⚠️ @TempData["ActiveTestAlert"]</strong>
        </div>
    }
    
    <p class="test-meta">
        שאלה @Model.DisplayQuestionNumber מתוך 17 · זמן נותר: <span id="countdown">--:--:--</span>
    </p>

    @if (!string.IsNullOrWhiteSpace(Model.QuestionImageUrl))
    {
        <img src="@Model.QuestionImageUrl" alt="שאלה" loading="lazy" id="main-question-image" class="test-main-question-image" />
    }

    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="questionIndex" value="@Model.CurrentIndex" />
        @if (ViewData["Token"] != null)
        {
            <input type="hidden" name="token" value="@ViewData["Token"]" />
        }

        <div class="answers">
            @foreach (var answer in Model.ShuffledAnswers ?? new Dictionary<string, string>())
            {
                <button type="submit"
                        name="answer"
                        value="@answer.Key"
                        class="answer-btn">
                    <img src="@(Model.AnswerImageUrls != null && Model.AnswerImageUrls.ContainsKey(answer.Key) ? Model.AnswerImageUrls[answer.Key] : "")" alt="תשובה" loading="lazy" />
                </button>
            }
        </div>
    </form>

</div>

<!-- Image Modal -->
<div id="image-modal" class="image-modal modal-hidden">
    <span class="close-modal" id="close-image-modal-btn">&times;</span>
    <img class="modal-content" id="modal-img" src="@Model.QuestionImageUrl" alt="שאלה מוגדלת" />
</div>

<div id="test-page-data" data-question-image-url="@Model.QuestionImageUrl" data-test-end-utc="@Model.TestEndUtcString"></div>
<script src="/js/test-page.js"></script>

<partial name="Shared/_SiteFooter" />
