@page
@model NoodlesSimulator.Pages.TestModel
@{
    ViewData["Title"] = "מצב מבחן";
    ViewData["ShowEndTestButton"] = true;
}
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — Test Mode</title>
    <link rel="stylesheet" href="/css/site.css" />
    <partial name="Shared/_SiteIcons" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#222222">
    <meta name="robots" content="noindex">
</head>
<body>

<img src="/assets/background.gif" alt="רקע" class="background-gif" />

<partial name="Shared/_TopBar" />

<partial name="Shared/_LogoHeader" />

<div class="quiz-container test-quiz-container">

    <h2 class="test-title">מצב מבחן</h2>
    
    @if (TempData["ActiveTestAlert"] != null)
    {
        <div class="test-active-alert">
            <strong class="test-active-alert-text">⚠️ @TempData["ActiveTestAlert"]</strong>
        </div>
    }

    <div class="test-progress-wrap">
        <div class="test-progress-track">
            <div class="test-progress-fill" id="test-progress-fill" style="width: @Model.ProgressPercent%"></div>
        </div>
        <p class="test-progress-label" id="test-progress-label">התקדמות: ענית על @Model.AnsweredCount / @Model.QuestionCount · שאלה @Model.DisplayQuestionNumber</p>
    </div>
    
    <p class="test-meta">
        שאלה <span id="test-question-number">@Model.DisplayQuestionNumber</span> מתוך @Model.QuestionCount · זמן נותר: <span id="countdown">--:--:--</span>
    </p>

    <div class="test-question-nav" id="test-question-nav" aria-label="ניווט בין שאלות">
        <button type="button" class="test-nav-arrow" id="test-prev-btn" aria-label="שאלה קודמת">▶</button>
        <div class="test-question-pills" id="test-question-pills" role="tablist">
            @for (var i = 0; i < Model.QuestionCount; i++)
            {
                var num = i + 1;
                var answered = i < Model.AnsweredByIndex.Count && Model.AnsweredByIndex[i];
                var current = i == Model.CurrentIndex;
                var pillClass = "test-question-pill";
                if (current) pillClass += " is-current";
                if (answered) pillClass += " is-answered";
                <button type="button"
                        class="@pillClass"
                        data-question-index="@i"
                        role="tab"
                        aria-selected="@(current ? "true" : "false")"
                        aria-label="שאלה @num@(answered ? " — נענתה" : "")">@num</button>
            }
        </div>
        <button type="button" class="test-nav-arrow" id="test-next-btn" aria-label="שאלה הבאה">◀</button>
    </div>
    <p class="test-nav-hint">אפשר לדלג בין שאלות ולחזור לענות מאוחר יותר — לא חייבים להישאר על שאלה אחת.</p>

    @if (!string.IsNullOrWhiteSpace(Model.QuestionImageUrl))
    {
        <img src="@Model.QuestionImageUrl" alt="שאלה" loading="lazy" id="main-question-image" class="test-main-question-image" />
    }

    <form method="post" id="test-answer-form">
        @Html.AntiForgeryToken()
        @if (ViewData["Token"] != null)
        {
            <input type="hidden" name="token" value="@ViewData["Token"]" />
        }

        <div class="answers" id="answers-grid">
            @foreach (var answer in Model.ShuffledAnswers ?? new Dictionary<string, string>())
            {
                var selected = answer.Key == Model.SelectedAnswerKey;
                <button type="submit"
                        name="answer"
                        value="@answer.Key"
                        class="answer-btn@(selected ? " is-selected" : "")"
                        aria-pressed="@(selected ? "true" : "false")">
                    <img src="@(Model.AnswerImageUrls != null && Model.AnswerImageUrls.ContainsKey(answer.Key) ? Model.AnswerImageUrls[answer.Key] : "")" alt="תשובה" loading="lazy" />
                </button>
            }
        </div>
    </form>

</div>

<!-- Image Modal -->
<div id="image-modal" class="image-modal modal-hidden">
    <span class="close-modal" id="close-image-modal-btn">&times;</span>
    <img class="modal-content" id="modal-img" src="@Model.QuestionImageUrl" alt="שאלה מוגדלת" />
</div>

<div id="test-page-data" data-test-remaining-seconds="@Model.TestRemainingSeconds"></div>
<script src="/js/dialog.js"></script>
<script src="/js/html-utils.js" asp-append-version="true"></script>
<script src="/js/image-modal.js" asp-append-version="true"></script>
<script src="/js/quiz-answers.js" asp-append-version="true"></script>
<script src="/js/quiz-viewport.js" asp-append-version="true"></script>
<script src="/js/test-page.js" asp-append-version="true"></script>

<partial name="Shared/_SiteFooter" />
</body>
</html>
