@page
@model NoodlesSimulator.Pages.IndexModel
@{
    ViewData["Title"] = "Noodles Simulator — Quiz";
    ViewData["ShowAdminLink"] = HttpContext.Session.GetString("IsAdmin") == "1";
    var modeLabel = Model.PracticeMode switch
    {
        "weak" => "תרגול חולשות",
        "review" => "סקירת טעויות",
        "daily" => "אתגר יומי",
        "normal" => Model.PracticeDifficulty switch
        {
            "easy" => "תרגול — קל",
            "medium" => "תרגול — בינוני",
            "hard" => "תרגול — קשה",
            _ => "תרגול חופשי"
        },
        _ => Model.PracticeDifficulty switch
        {
            "easy" => "תרגול — קל",
            "medium" => "תרגול — בינוני",
            "hard" => "תרגול — קשה",
            _ => "תרגול חופשי"
        }
    };
    var isFreePractice = string.IsNullOrEmpty(Model.PracticeMode) || Model.PracticeMode == "normal";

    var reportCorrectAnswer = "";
    var reportAnswersJson = "";
    if (Model.AnswerChecked
        && !string.IsNullOrEmpty(Model.CorrectAnswerKey)
        && Model.ShuffledAnswers != null
        && Model.ShuffledAnswers.TryGetValue(Model.CorrectAnswerKey, out var reportCorrectFile))
    {
        reportCorrectAnswer = reportCorrectFile;
        reportAnswersJson = System.Text.Json.JsonSerializer.Serialize(Model.ShuffledAnswers);
    }
}
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — Quiz</title>
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />
    <partial name="Shared/_SiteIcons" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#222222">
</head>
<body>

<img src="/assets/background.gif" alt="רקע" class="background-gif" loading="lazy" fetchpriority="low" decoding="async" />

<partial name="Shared/_TopBar" />
<partial name="Shared/_LogoHeader" />

<p class="quiz-meta quiz-meta-user">
    👤 Logged in as <strong>@Model.Username</strong>
</p>

<p class="quiz-meta quiz-meta-online">
    🟢 מחוברים כעת: <strong id="online-count">@Model.OnlineCount</strong>
</p>

<div class="practice-mode-stack">
    <div class="practice-mode-top">
        <p class="practice-mode-badge" id="practice-mode-badge">
            @modeLabel
            @if (Model.PracticeMode == "daily")
            {
                <span class="practice-mode-daily">@Model.DailyProgress/@Model.DailyTotal</span>
            }
        </p>
    </div>
    <div class="practice-mode-streak">
        <span class="streak-badge" id="streak-badge" @(Model.CurrentStreak > 0 ? "" : "hidden") aria-label="רצף תשובות נכונות">
            <img src="/images/streak/flame-icon.gif?v=3" alt="" class="streak-flame-bg" width="300" height="300" decoding="async" aria-hidden="true" />
            <span class="streak-badge-text" id="streak-badge-text">@Model.CurrentStreak</span>
        </span>
    </div>
    <div class="level-progress-live" id="level-progress-live" aria-label="התקדמות רמה">
        <span class="level-progress-live-label">רמה <strong id="live-level">@Model.UserLevel</strong></span>
        <div class="level-progress-live-track" aria-hidden="true">
            <div class="level-progress-live-fill" id="live-xp-fill" style="--xp-progress: @Model.XpProgressPercent%"></div>
        </div>
        <span class="level-progress-live-meta" id="live-xp-meta">
            נותר @QuizGamification.XpToNextLevel(Model.UserXp) XP לרמה ההבאה
        </span>
    </div>
</div>

@if (Model.NewlyUnlockedAchievements.Count > 0)
{
    <div id="achievement-toast" class="achievement-toast" hidden>
        @foreach (var key in Model.NewlyUnlockedAchievements)
        {
            var def = NoodlesSimulator.Models.AchievementCatalog.Find(key);
            if (def != null)
            {
                <p class="achievement-toast-item">@def.Emoji הישג חדש: <strong>@def.Title</strong> — @def.Description</p>
            }
        }
    </div>
}

<div id="quiz-page-data"
     data-answer-checked="@(Model.AnswerChecked ? "1" : "0")"
     data-has-explanation="@(Model.HasExplanation ? "1" : "0")"
     hidden></div>

<div class="quiz-container">
    <img src="@Model.QuestionImageUrl" alt="שאלה" loading="eager" fetchpriority="high" id="main-question-image" class="quiz-main-image" />

    <form method="post" id="quiz-answer-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="questionImage" id="quiz-question-image" value="@Model.QuestionImage" />

        <div class="answers" id="answers-grid">
            @foreach (var answer in Model.ShuffledAnswers ?? new Dictionary<string, string>())
            {
                var answerClass = "";
                if (Model.AnswerChecked)
                {
                    if (answer.Key == Model.CorrectAnswerKey)
                        answerClass = "correct" + (Model.IsCorrect ? " answer-pulse" : " answer-reveal-correct");
                    else if (Model.SelectedAnswer == answer.Key)
                        answerClass = "incorrect answer-shake";
                }

                <button type="submit"
                        name="answer"
                        value="@answer.Key"
                        class="answer-btn @answerClass"
                        @(Model.AnswerChecked ? "disabled" : "")>
                    <img src="@(Model.AnswerImageUrls != null && Model.AnswerImageUrls.ContainsKey(answer.Key) ? Model.AnswerImageUrls[answer.Key] : "")" alt="תשובה" loading="lazy" data-answer-file="@answer.Value" />
                </button>
            }
        </div>
    </form>

    @if (Model.AnswerChecked)
    {
        <p class="quiz-answer-feedback @(Model.IsCorrect ? "is-correct" : "is-incorrect")" id="answer-feedback">
            @(Model.IsCorrect ? "תשובה נכונה!" : "תשובה שגויה")
        </p>
    }
    else
    {
        <p class="quiz-answer-feedback" id="answer-feedback" hidden></p>
    }

    <div id="question-explanation-panel" class="question-explanation-panel" hidden aria-live="polite">
        <button type="button" id="question-explanation-btn" class="secondary-btn question-explanation-btn">
            <span id="question-explanation-btn-text">הסבר</span>
        </button>
        <div id="question-explanation-video-wrap" class="question-explanation-video-wrap" hidden>
            <video id="question-explanation-video" class="question-explanation-video" controls playsinline preload="metadata"></video>
        </div>
        <partial name="Shared/_QuestionExplanationRating" />
    </div>

    <p class="quiz-keyboard-hint" id="quiz-keyboard-hint">קיצורים: 1–4 לבחירה · Enter לשאלה הבאה</p>

    <div class="button-row">
        <form class="inline-form-reset">
            <button type="button"
                    class="next-question-btn practice-options-icon-btn"
                    id="open-practice-options-btn"
                    title="אפשרויות תרגול"
                    aria-label="אפשרויות תרגול">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <line x1="4" y1="7" x2="20" y2="7" />
                    <line x1="4" y1="12" x2="20" y2="12" />
                    <line x1="4" y1="17" x2="20" y2="17" />
                </svg>
            </button>
        </form>
        <form class="inline-form-reset">
            <button type="button" class="next-question-btn" id="open-difficulty-modal-btn">מצב מבחן</button>
        </form>
        <form method="get" id="next-question-form">
            <input type="hidden" name="next" value="1" />
            @if (!string.IsNullOrEmpty(Model.PracticeMode) && Model.PracticeMode != "normal")
            {
                <input type="hidden" name="mode" value="@Model.PracticeMode" />
            }
            @if (!string.IsNullOrEmpty(Model.PracticeDifficulty))
            {
                <input type="hidden" name="difficulty" value="@Model.PracticeDifficulty" />
            }
            <button type="submit" class="next-question-btn" id="next-question-btn">שאלה הבאה</button>
        </form>
    </div>
</div>

@if (Model.ShowWelcomeModal)
{
    <div id="welcome-prompt" data-course-url="@WelcomePrompt.CourseUrl" hidden></div>
    <div id="welcome-modal" class="difficulty-modal welcome-modal">
        <div class="difficulty-modal-content welcome-modal-content">
            <div class="welcome-modal-scroll">
                <span class="welcome-modal-badge">מומלץ</span>
                <h2 class="difficulty-modal-title welcome-modal-title">@WelcomePrompt.Title</h2>
                <p class="difficulty-modal-message welcome-modal-subtitle">@WelcomePrompt.Subtitle</p>
                <ul class="app-notice-list welcome-modal-features">
                    @foreach (var feature in WelcomePrompt.PlatformFeatures)
                    {
                        <li>@feature</li>
                    }
                </ul>
                <div class="welcome-modal-recommend">
                    <p class="welcome-modal-recommend-title">@WelcomePrompt.RecommendTitle</p>
                    <p class="welcome-modal-recommend-body">@WelcomePrompt.RecommendBody</p>
                    <blockquote class="welcome-modal-testimonial">@WelcomePrompt.PersonalTestimonial</blockquote>
                </div>
            </div>
            <div class="difficulty-buttons welcome-modal-buttons">
                <button type="button" class="difficulty-btn difficulty-easy welcome-modal-cta" id="welcome-cs24-btn">@WelcomePrompt.AcceptButton</button>
                <button type="button" class="difficulty-btn difficulty-medium" id="welcome-skip-btn">@WelcomePrompt.SkipButton</button>
            </div>
        </div>
    </div>
}

<div id="feedback-prompt"
     data-campaign-id="@(Model.ShowFeedbackModal ? Model.FeedbackCampaignId : "")"
     data-milestone="@(Model.ShowFeedbackModal ? Model.FeedbackMilestone : 0)"
     data-has-welcome="@(Model.ShowWelcomeModal ? "1" : "0")"
     hidden></div>
<div id="feedback-modal" class="difficulty-modal feedback-modal">
    <div class="difficulty-modal-content feedback-modal-content">
        <h2 class="difficulty-modal-title">@FeedbackCampaigns.Title</h2>
        <p class="difficulty-modal-message feedback-modal-subtitle">@FeedbackCampaigns.Subtitle</p>

        <div class="feedback-stars" id="feedback-stars" role="radiogroup" aria-label="דירוג">
            @for (var star = 1; star <= 5; star++)
            {
                <button type="button"
                        class="feedback-star"
                        data-rating="@star"
                        aria-label="דירוג @star מתוך 5">★</button>
            }
        </div>

        <label for="feedback-message" class="feedback-message-label">משוב (אופציונלי)</label>
        <textarea id="feedback-message"
                  class="feedback-message-input"
                  maxlength="2000"
                  rows="4"
                  placeholder="ספר לנו מה אהבת, מה היית משפר, או כל דבר אחר..."></textarea>

        <div class="difficulty-buttons feedback-modal-buttons">
            <button type="button" class="difficulty-btn difficulty-easy" id="feedback-submit-btn" disabled>שליחה</button>
            <button type="button" class="difficulty-btn difficulty-medium" id="feedback-later-btn">אולי אחר כך</button>
        </div>
    </div>
</div>

@if (Model.ShowGitHubStarModal)
{
    <div id="github-star-prompt"
         data-milestone="@Model.GitHubStarMilestone"
         data-repo-url="@GitHubStarPrompt.RepoUrl"
         data-has-welcome="@(Model.ShowWelcomeModal ? "1" : "0")"
         data-has-feedback="@(Model.ShowFeedbackModal ? "1" : "0")"
         hidden></div>
}

<div id="github-star-modal" class="difficulty-modal github-star-modal">
    <div class="difficulty-modal-content github-star-modal-content">
        <h2 class="difficulty-modal-title">@GitHubStarPrompt.Title</h2>
        <p class="difficulty-modal-message github-star-modal-subtitle">@GitHubStarPrompt.Subtitle</p>
        <div class="difficulty-buttons github-star-modal-buttons">
            <button type="button" class="difficulty-btn difficulty-easy" id="github-star-accept-btn">@GitHubStarPrompt.AcceptButton</button>
            <button type="button" class="difficulty-btn difficulty-medium" id="github-star-later-btn">@GitHubStarPrompt.LaterButton</button>
        </div>
    </div>
</div>

<div id="practice-options-modal" class="difficulty-modal">
    <div class="difficulty-modal-content practice-options-content">
        <span class="close-difficulty-modal" id="close-practice-options-btn">&times;</span>
        <h2 class="difficulty-modal-title">אפשרויות תרגול</h2>

        <p class="practice-options-section-title">מצב תרגול</p>
        <div class="practice-options-list">
            <a href="/Index?mode=normal" class="practice-option-btn @(isFreePractice && string.IsNullOrEmpty(Model.PracticeDifficulty) ? "is-active" : "")">תרגול חופשי</a>
            <a href="/Index?mode=weak" class="practice-option-btn @(Model.PracticeMode == "weak" ? "is-active" : "")">תרגול חולשות</a>
            <a href="/Index?mode=review" class="practice-option-btn @(Model.PracticeMode == "review" ? "is-active" : "")">סקירת טעויות</a>
            <a href="/Index?mode=daily" class="practice-option-btn @(Model.PracticeMode == "daily" ? "is-active" : "")">אתגר יומי</a>
        </div>

        <p class="practice-options-section-title">רמת קושי</p>
        <div class="practice-options-list">
            <a href="/Index?mode=normal&amp;difficulty=easy" class="practice-option-btn @(Model.PracticeDifficulty == "easy" ? "is-active" : "")">קל</a>
            <a href="/Index?mode=normal&amp;difficulty=medium" class="practice-option-btn @(Model.PracticeDifficulty == "medium" ? "is-active" : "")">בינוני</a>
            <a href="/Index?mode=normal&amp;difficulty=hard" class="practice-option-btn @(Model.PracticeDifficulty == "hard" ? "is-active" : "")">קשה</a>
        </div>
    </div>
</div>

<div id="difficulty-modal" class="difficulty-modal">
    <div class="difficulty-modal-content">
        <span class="close-difficulty-modal" id="close-difficulty-modal-btn">&times;</span>
        <h2 class="difficulty-modal-title">בחר רמת קושי למבחן</h2>
        <div class="difficulty-buttons">
            <a href="/Test?start=1&amp;difficulty=easy" class="difficulty-btn difficulty-easy" data-difficulty="easy">
                <span class="difficulty-text">קל</span>
            </a>
            <a href="/Test?start=1&amp;difficulty=medium" class="difficulty-btn difficulty-medium" data-difficulty="medium">
                <span class="difficulty-text">בינוני</span>
            </a>
            <a href="/Test?start=1&amp;difficulty=hard" class="difficulty-btn difficulty-hard" data-difficulty="hard">
                <span class="difficulty-text">קשה</span>
            </a>
        </div>
    </div>
</div>

<div id="daily-complete-modal" class="difficulty-modal daily-complete-modal">
    <div class="difficulty-modal-content daily-complete-content">
        <h2 class="difficulty-modal-title">🎯 סיימת אתגר יומי!</h2>
        <p class="difficulty-modal-message" id="daily-complete-score"></p>
        <p class="difficulty-modal-message daily-complete-sub">חזור מחר לאתגר חדש, או המשך בתרגול חופשי.</p>
        <div class="difficulty-buttons difficulty-buttons-single">
            <button type="button" class="difficulty-btn difficulty-easy" id="daily-complete-dismiss-btn">המשך</button>
        </div>
    </div>
</div>

<div id="image-modal" class="image-modal">
    <span class="close-modal" id="close-image-modal-btn">&times;</span>
    <img class="modal-content" id="modal-img" src="@Model.QuestionImageUrl" alt="שאלה מוגדלת" />
</div>

<div class="report-container">
    <form id="report-form" class="report-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="questionImage" value="@(Model.QuestionImageOriginalName ?? Model.QuestionImage)" />
        <input type="hidden" name="selectedAnswer" value="@Model.SelectedAnswer" />
        <input type="hidden" name="correctAnswer" value="@reportCorrectAnswer" />
        <input type="hidden" name="answers" value="@reportAnswersJson" />
        <label for="explanation" class="report-label">יש טעות בשאלה? תקלה באתר? דווח לנו!</label>
        <textarea name="explanation" id="explanation" required placeholder="נא לפרט מה לא תקין..." class="report-textarea"></textarea>
        <button type="submit" class="next-question-btn report-submit-btn">דווח על טעות בשאלה</button>
    </form>
</div>

<div class="site-footer-wrap">
    <div id="stats-panel" class="stats-drawer" aria-hidden="true">
        <div class="stats-drawer-inner">
            <div class="stats-drawer-metric">
                <span class="stats-drawer-value" id="stat-correct-panel">@Model.UserCorrect</span>
                <span class="stats-drawer-label">נכונות</span>
            </div>
            <div class="stats-drawer-metric">
                <span class="stats-drawer-value" id="stat-total-panel">@Model.UserTotal</span>
                <span class="stats-drawer-label">שאלות</span>
            </div>
            <div class="stats-drawer-metric">
                <span class="stats-drawer-value" id="stat-success-panel">@Model.UserSuccessRate%</span>
                <span class="stats-drawer-label">אחוז</span>
            </div>
            <div class="stats-drawer-metric">
                <span class="stats-drawer-value" id="stat-streak">@Model.CurrentStreak</span>
                <span class="stats-drawer-label">רצף</span>
            </div>
            <div class="stats-drawer-metric">
                <span class="stats-drawer-value" id="stat-level-value">@Model.UserLevel</span>
                <span class="stats-drawer-label">רמה</span>
            </div>
            <div class="stats-drawer-metric">
                <span class="stats-drawer-value" id="stat-xp-value">@Model.UserXp</span>
                <span class="stats-drawer-label">XP</span>
            </div>
            <label class="stats-drawer-sound" title="צלילי משוב">
                <input type="checkbox" id="sound-toggle" checked />
                <span>צליל</span>
            </label>
            <a href="/Stats" class="stats-drawer-more-btn">הצג עוד</a>
        </div>
        <div class="stats-drawer-advanced">
            <button type="button"
                    class="stats-drawer-advanced-toggle"
                    id="stats-advanced-toggle"
                    aria-expanded="false"
                    aria-controls="stats-advanced-panel">
                אפשרויות מתקדמות
                <span class="stats-drawer-advanced-chevron" aria-hidden="true">▾</span>
            </button>
            <div id="stats-advanced-panel" class="stats-drawer-advanced-panel" hidden>
                <p class="stats-drawer-advanced-hint">מאפס סטטיסטיקה, XP, רמה, רצף והישגים. לא ניתן לבטל.</p>
                <form method="post" id="reset-progress-form" class="stats-drawer-reset-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reset" value="1" />
                    <button type="submit" class="stats-drawer-reset-btn">איפוס התקדמות</button>
                </form>
            </div>
        </div>
    </div>

    <partial name="Shared/_SiteFooter" />
</div>

<script src="/js/dialog.js"></script>
<script src="/js/html-utils.js" asp-append-version="true"></script>
<script src="/js/image-modal.js" asp-append-version="true"></script>
<script src="/js/quiz-answers.js" asp-append-version="true"></script>
<script src="/js/request-channels.js" asp-append-version="true"></script>
<script src="/js/quiz-viewport.js" asp-append-version="true"></script>
<script src="/js/index-page.js" asp-append-version="true"></script>
<script src="/js/index-modals.js" asp-append-version="true"></script>
<script src="/js/index-quiz-prefetch.js" asp-append-version="true"></script>
<script src="/js/index-quiz-feedback.js" asp-append-version="true"></script>
<script src="/js/question-explanation.js" asp-append-version="true"></script>
<script src="/js/index-quiz.js" asp-append-version="true"></script>
</body>
</html>
