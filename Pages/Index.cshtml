@page
@model NoodlesSimulator.Pages.IndexModel
@{
    ViewData["Title"] = "Noodles Simulator — Quiz";
    ViewData["ShowAdminLink"] = HttpContext.Session.GetString("IsAdmin") == "1";
    var modeLabel = Model.PracticeMode switch
    {
        "weak" => "תרגול חולשות",
        "review" => "סקירת טעויות",
        "daily" => "אתגר יומי",
        _ => !string.IsNullOrEmpty(Model.PracticeDifficulty) ? $"תרגול — {Model.PracticeDifficulty}" : "תרגול חופשי"
    };
}
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — Quiz</title>
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />
    <partial name="Shared/_SiteIcons" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#222222">
</head>
<body>

<img src="/assets/background.gif" alt="רקע" class="background-gif" />

<partial name="Shared/_TopBar" />
<partial name="Shared/_LogoHeader" />

<p class="quiz-meta quiz-meta-user">
    👤 Logged in as <strong>@Model.Username</strong>
    @if (Model.CurrentStreak > 0)
    {
        <span class="streak-badge" id="streak-badge">🔥 @Model.CurrentStreak ברצף</span>
    }
</p>

<p class="quiz-meta quiz-meta-online">
    🟢 מחוברים כעת: <strong id="online-count">@Model.OnlineCount</strong>
</p>

<div class="quiz-stats-card" id="quiz-stats-card">
    <div class="quiz-stats-row">
        <span>✅ <strong id="stat-correct">@Model.UserCorrect</strong> נכונות</span>
        <span>📋 <strong id="stat-total">@Model.UserTotal</strong> שאלות</span>
        <span>📈 <strong id="stat-success">@Model.UserSuccessRate%</strong></span>
    </div>
    <div class="xp-bar-wrap">
        <span class="xp-level-label">רמה @Model.UserLevel</span>
        <div class="xp-bar-track">
            <div class="xp-bar-fill" style="width: @Model.XpProgressPercent%"></div>
        </div>
        <span class="xp-points-label">@Model.UserXp XP</span>
    </div>
    <p class="practice-mode-label">מצב: <strong>@modeLabel</strong>
        @if (Model.PracticeMode == "daily")
        {
            <span> — @Model.DailyProgress/@Model.DailyTotal</span>
        }
    </p>
</div>

@if (Model.NewlyUnlockedAchievements.Count > 0)
{
    <div id="achievement-toast" class="achievement-toast">
        @foreach (var key in Model.NewlyUnlockedAchievements)
        {
            var def = NoodlesSimulator.Models.AchievementCatalog.Find(key);
            if (def != null)
            {
                <p class="achievement-toast-item">@def.Emoji הישג חדש: <strong>@def.Title</strong> — @def.Description</p>
            }
        }
    </div>
}

<div class="quiz-container">
    <img src="@Model.QuestionImageUrl" alt="שאלה" loading="lazy" id="main-question-image" class="quiz-main-image" />

    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="questionImage" value="@Model.QuestionImage" />
        <input type="hidden" name="answersJson" value='@System.Text.Json.JsonSerializer.Serialize(Model.ShuffledAnswers, NoodlesSimulator.Models.AppJson.Options)' />

        <div class="answers" id="answers-grid">
            @foreach (var answer in Model.ShuffledAnswers ?? new Dictionary<string, string>())
            {
                var answerClass = "";
                if (Model.AnswerChecked)
                {
                    if (answer.Key == "correct")
                        answerClass = "correct" + (Model.IsCorrect ? " answer-pulse" : " answer-reveal-correct");
                    else if (Model.SelectedAnswer == answer.Key)
                        answerClass = "incorrect answer-shake";
                }

                <button type="submit"
                        name="answer"
                        value="@answer.Key"
                        class="answer-btn @answerClass"
                        @(Model.AnswerChecked ? "disabled" : "")>
                    <img src="@(Model.AnswerImageUrls != null && Model.AnswerImageUrls.ContainsKey(answer.Key) ? Model.AnswerImageUrls[answer.Key] : "")" alt="תשובה" loading="lazy" />
                </button>
            }
        </div>
    </form>

    @if (Model.AnswerChecked)
    {
        <p class="quiz-answer-feedback @(Model.IsCorrect ? "is-correct" : "is-incorrect")" id="answer-feedback">
            @(Model.IsCorrect ? "תשובה נכונה!" : "תשובה שגויה")
        </p>
    }

    <div class="practice-modes-row">
        <a href="/Index?mode=weak" class="mode-btn">💪 חולשות</a>
        <a href="/Index?difficulty=easy" class="mode-btn mode-easy">🟢 קל</a>
        <a href="/Index?difficulty=medium" class="mode-btn mode-medium">🟡 בינוני</a>
        <a href="/Index?difficulty=hard" class="mode-btn mode-hard">🔴 קשה</a>
        <a href="/Index?mode=review" class="mode-btn">🔁 טעויות</a>
        <a href="/Index?mode=daily" class="mode-btn mode-daily">📅 אתגר יומי</a>
        <a href="/Index" class="mode-btn mode-normal">🎯 רגיל</a>
    </div>

    <div class="button-row">
        <form class="inline-form-reset">
            <button type="button" class="next-question-btn" id="open-difficulty-modal-btn">מצב מבחן</button>
        </form>
        <form method="get">
            @if (!string.IsNullOrEmpty(Model.PracticeMode) && Model.PracticeMode != "normal")
            {
                <input type="hidden" name="mode" value="@Model.PracticeMode" />
            }
            @if (!string.IsNullOrEmpty(Model.PracticeDifficulty))
            {
                <input type="hidden" name="difficulty" value="@Model.PracticeDifficulty" />
            }
            <button class="next-question-btn">שאלה הבאה</button>
        </form>

        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reset" value="1" />
            <button class="next-question-btn next-question-btn-danger">איפוס שאלות</button>
        </form>
    </div>
</div>

@if (Model.ShowExamFixNotice)
{
    <div id="exam-fix-notice-prompt" data-notice-id="@AppNotices.ExamFix" hidden></div>
    <div id="exam-fix-notice-modal" class="difficulty-modal exam-fix-notice-modal">
        <div class="difficulty-modal-content">
            <span class="close-difficulty-modal" id="close-exam-fix-notice-btn">&times;</span>
            <h2 class="difficulty-modal-title">מצב המבחן תוקן</h2>
            <p class="difficulty-modal-message">תיקנו בעיה במצב המבחן. אפשר להתחיל מבחן חדש בלחיצה על «מצב מבחן» בדף הבית.</p>
            <div class="difficulty-buttons difficulty-buttons-single">
                <button type="button" class="difficulty-btn difficulty-easy" id="exam-fix-notice-dismiss-btn">הבנתי</button>
            </div>
        </div>
    </div>
}

<div id="difficulty-modal" class="difficulty-modal">
    <div class="difficulty-modal-content">
        <span class="close-difficulty-modal" id="close-difficulty-modal-btn">&times;</span>
        <h2 class="difficulty-modal-title">בחר רמת קושי</h2>
        <div class="difficulty-buttons">
            <a href="/Test?start=1&amp;difficulty=easy" class="difficulty-btn difficulty-easy" data-difficulty="easy">
                <span class="difficulty-emoji">🟢</span>
                <span class="difficulty-text">קל</span>
            </a>
            <a href="/Test?start=1&amp;difficulty=medium" class="difficulty-btn difficulty-medium" data-difficulty="medium">
                <span class="difficulty-emoji">🟡</span>
                <span class="difficulty-text">בינוני</span>
            </a>
            <a href="/Test?start=1&amp;difficulty=hard" class="difficulty-btn difficulty-hard" data-difficulty="hard">
                <span class="difficulty-emoji">🔴</span>
                <span class="difficulty-text">קשה</span>
            </a>
        </div>
    </div>
</div>

<div id="image-modal" class="image-modal">
    <span class="close-modal" id="close-image-modal-btn">&times;</span>
    <img class="modal-content" id="modal-img" src="@Model.QuestionImageUrl" alt="שאלה מוגדלת" />
</div>

<div class="report-container">
    <form id="report-form" class="report-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="questionImage" value="@(Model.QuestionImageOriginalName ?? Model.QuestionImage)" />
        <input type="hidden" name="answersJson" value='@System.Text.Json.JsonSerializer.Serialize(Model.AnswerImageOriginalNames ?? Model.ShuffledAnswers, NoodlesSimulator.Models.AppJson.Options)' />
        <input type="hidden" name="correctAnswer" value='@((Model.AnswerImageOriginalNames != null && Model.AnswerImageOriginalNames.ContainsKey("correct")) ? Model.AnswerImageOriginalNames["correct"] : (Model.ShuffledAnswers != null && Model.ShuffledAnswers.ContainsKey("correct") ? Model.ShuffledAnswers["correct"] : ""))' />
        <input type="hidden" name="selectedAnswer" value="@Model.SelectedAnswer" />
        <label for="explanation" class="report-label">יש טעות בשאלה?, תקלה באתר? דווח לנו!</label>
        <textarea name="explanation" id="explanation" required placeholder="נא לפרט מה לא תקין..." class="report-textarea"></textarea>
        <button type="submit" class="next-question-btn report-submit-btn">דווח על טעות בשאלה</button>
    </form>
</div>

<div id="stats-panel" class="hidden">
    <h3>📊 סטטיסטיקה אישית</h3>
    <ul>
        <li>✅ תשובות נכונות: <span id="stat-correct-panel">@Model.UserCorrect</span></li>
        <li>📋 שאלות שנענו: <span id="stat-total-panel">@Model.UserTotal</span></li>
        <li>📈 אחוז הצלחה: <span id="stat-success-panel">@Model.UserSuccessRate%</span></li>
        <li>🔥 רצף נוכחי: <span id="stat-streak">@Model.CurrentStreak</span></li>
        <li>⭐ רמה: <span id="stat-level">@Model.UserLevel</span> (@Model.UserXp XP)</li>
    </ul>
    <label class="sound-toggle-label">
        <input type="checkbox" id="sound-toggle" checked /> צלילי משוב
    </label>
</div>

<script src="/js/dialog.js"></script>
<script src="/js/index-page.js" asp-append-version="true"></script>

<partial name="Shared/_SiteFooter" />
</body>
</html>
