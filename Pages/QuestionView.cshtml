@page
@model NoodlesSimulator.Pages.QuestionViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — צפייה בשאלה</title>
    <link rel="stylesheet" href="/css/site.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
    <a href="/Dashboard" class="back-to-quiz">⬅ חזרה לניהול</a>
    <img src="/assets/background.gif" class="background-gif" alt="רקע" />

    <partial name="Shared/_LogoHeader" />

    <div class="quiz-container">
        @if (!string.IsNullOrWhiteSpace(Model.QuestionImageUrl))
        {
            <img src="@Model.QuestionImageUrl" alt="שאלה" loading="lazy" id="main-question-image" class="question-view-main-image" />
        }

        <div class="answers">
            @foreach (var kv in Model.AnswerImageUrls)
            {
                var answerClass = "";
                if (Model.ShowAnswerResults)
                {
                    // Mark correct answer in green
                    if (kv.Key == Model.CorrectAnswerKey)
                    {
                        answerClass = "correct";
                    }
                    // Mark selected (wrong) answer in red
                    else if (kv.Key == Model.SelectedAnswerKey)
                    {
                        answerClass = "incorrect";
                    }
                }

                <button class="answer-btn @answerClass question-view-answer-btn" disabled>
                    <img src="@kv.Value" alt="תשובה" loading="lazy" class="question-view-answer-image" />
                </button>
            }
        </div>
        
        @if (Model.ShowAnswerResults)
        {
            var isCorrect = Model.SelectedAnswerKey == Model.CorrectAnswerKey;
            <p class="question-view-result @(isCorrect ? "question-view-result-correct" : "question-view-result-incorrect")">
                @(isCorrect ? "✓ תשובה נכונה!" : "✗ תשובה שגויה")
            </p>
        }
    </div>

    <!-- Image Modal -->
    <div id="image-modal" class="image-modal modal-hidden">
        <span class="close-modal" id="close-image-modal-btn">&times;</span>
        <img class="modal-content" id="modal-img" src="@Model.QuestionImageUrl" alt="שאלה מוגדלת" />
    </div>

    <div id="question-view-data" data-question-image-url="@Model.QuestionImageUrl"></div>
    <script src="/js/questionview-page.js"></script>

    <partial name="Shared/_SiteFooter" />
</body>
</html>


