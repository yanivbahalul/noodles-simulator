@page
@model NoodlesSimulator.Pages.LoginModel
@{
    ViewData["Title"] = "התחברות / הרשמה";
}
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — התחברות / הרשמה</title>
    <link rel="stylesheet" href="/css/site.css" />
    <partial name="Shared/_SiteIcons" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#222222">
</head>
<body>
<!-- background -->
<img src="/assets/background.gif" alt="רקע" class="background-gif" />
<!-- logo -->
<partial name="Shared/_LogoHeader" />
<!-- login button  -->
<div class="login-container login-panel">
    <h2 class="login-title">ברוכים הבאים!</h2>
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p class="error-message @(Model.ErrorMessage.Contains("נחסם") ? "login-error-banned" : "login-error-regular")">
            @Model.ErrorMessage
        </p>
    }
    @if (Model.ShowAdminOtp)
    {
        <p class="login-label">נשלח קוד אימות למייל שלך. הזן אותו כדי להשלים התחברות.</p>
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="login-fields">
                <label for="otp" class="login-label">קוד אימות</label>
                <input type="text" name="OtpCode" id="otp" class="input-field"
                       inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code"
                       required />
            </div>
            <div class="login-actions">
                <button type="submit" name="action" value="verify-admin-otp" class="main-btn login-action-btn">אימות</button>
                <button type="submit" name="action" value="resend-admin-otp" class="secondary-btn login-action-btn">שלח קוד שוב</button>
                <button type="submit" name="action" value="cancel-admin-otp" class="secondary-btn login-action-btn">חזרה להתחברות</button>
            </div>
        </form>
    }
    else
    {
    <form method="post">
        @Html.AntiForgeryToken()
        <div class="login-fields">
            <label for="username" class="login-label">שם משתמש</label>
            <input type="text" name="Username" id="username" class="input-field"
                   value="@Model.Username"
                   required />
            <label for="password" class="login-label">סיסמה</label>
            <input type="password" name="Password" id="password" class="input-field"
                   required />
        </div>
        <div class="login-actions">
            <button type="submit" name="action" value="login" class="main-btn login-action-btn">התחברות</button>
            <button type="submit" name="action" value="register" class="secondary-btn login-action-btn">הרשמה</button>
        </div>
    </form>
    }
</div>

<partial name="Shared/_SiteFooter" />
</body>
</html>
