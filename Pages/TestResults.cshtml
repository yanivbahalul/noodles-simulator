@page
@model NoodlesSimulator.Pages.TestResultsModel
@{
    ViewData["Title"] = "סיכום מבחן";
    var startIndex = Model.InitialIndex;
    var startItem = Model.Items.Count > startIndex ? Model.Items[startIndex] : null;
    var progressPercent = Model.Total > 0 ? (Model.CorrectCount * 100 / Model.Total) : 0;
}
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — Test Summary</title>
    <link rel="stylesheet" href="/css/site.css" />
    <partial name="Shared/_SiteIcons" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#222222">
    <meta name="robots" content="noindex">
</head>
<body>

<img src="/assets/background.gif" alt="רקע" class="background-gif" />

<partial name="Shared/_TopBar" />
<partial name="Shared/_LogoHeader" />

<div class="quiz-container test-quiz-container test-results-container">

    <h2 class="test-title">סיכום מבחן</h2>

    <p class="test-results-summary">
        ניקוד: <strong>@Model.Score</strong> מתוך @Model.MaxScore
        · <strong>@Model.CorrectCount</strong> תשובות נכונות מתוך @Model.Total
        · זמן: <strong>@Model.ElapsedText</strong>
    </p>

    <div class="test-progress-wrap">
        <div class="test-progress-track">
            <div class="test-progress-fill test-results-progress-fill" id="test-results-progress-fill" style="width: @progressPercent%"></div>
        </div>
        <p class="test-progress-label" id="test-results-progress-label">@Model.CorrectCount / @Model.Total נכונות</p>
    </div>

    <p class="test-meta">
        שאלה <span id="test-results-question-number">@(startIndex + 1)</span> מתוך @Model.Total
        · <span id="test-results-question-status" class="test-results-question-status@(startItem == null ? "" : startItem.IsCorrect ? " is-correct" : startItem.IsAnswered ? " is-wrong" : " is-unanswered")">
            @if (startItem == null)
            {
                @:—
            }
            else if (startItem.IsCorrect)
            {
                @:✓ נכון
            }
            else if (startItem.IsAnswered)
            {
                @:✗ לא נכון
            }
            else
            {
                @:לא ענית
            }
        </span>
    </p>

    <div class="test-question-nav" id="test-results-question-nav" aria-label="ניווט בין שאלות">
        <button type="button" class="test-nav-arrow" id="test-results-prev-btn" aria-label="שאלה קודמת">▶</button>
        <div class="test-question-pills" id="test-results-question-pills" role="tablist">
            @for (var i = 0; i < Model.Items.Count; i++)
            {
                var item = Model.Items[i];
                var num = i + 1;
                var current = i == startIndex;
                var pillClass = "test-question-pill";
                if (current) pillClass += " is-current";
                if (item.IsCorrect) pillClass += " is-correct";
                else if (item.IsAnswered) pillClass += " is-wrong";
                else pillClass += " is-unanswered";
                <button type="button"
                        class="@pillClass"
                        data-question-index="@i"
                        role="tab"
                        aria-selected="@(current ? "true" : "false")"
                        aria-label="שאלה @num@(item.IsCorrect ? " — נכון" : item.IsAnswered ? " — לא נכון" : " — לא נענתה")">@num</button>
            }
        </div>
        <button type="button" class="test-nav-arrow" id="test-results-next-btn" aria-label="שאלה הבאה">◀</button>
    </div>
    <p class="test-nav-hint test-results-nav-hint">ירוק = נכון · אדום = הטעות שלך · אפשר לעבור בין כל השאלות ולראות את התשובה הנכונה</p>

    @if (startItem != null && !string.IsNullOrWhiteSpace(startItem.QuestionUrl))
    {
        <img src="@startItem.QuestionUrl" alt="שאלה" loading="lazy" id="test-results-question-image" class="test-main-question-image" />
    }
    else
    {
        <img src="" alt="שאלה" loading="lazy" id="test-results-question-image" class="test-main-question-image" hidden />
    }

    <div class="answers" id="test-results-answers-grid">
        @if (startItem != null)
        {
            @foreach (var kv in startItem.AnswerUrls)
            {
                var key = kv.Key;
                var url = kv.Value;
                var cls = "answer-btn";
                if (key == startItem.CorrectKey) cls += " correct";
                else if (key == startItem.SelectedKey && !startItem.IsCorrect) cls += " incorrect";
                <button type="button" class="@cls" disabled>
                    <img src="@url" alt="תשובה" loading="lazy" />
                </button>
            }
        }
    </div>

    <div id="question-explanation-panel" class="question-explanation-panel" hidden aria-live="polite">
        <button type="button" id="question-explanation-btn" class="secondary-btn question-explanation-btn">
            <span id="question-explanation-btn-text">הסבר</span>
        </button>
        <div id="question-explanation-video-wrap" class="question-explanation-video-wrap" hidden>
            <button type="button" id="question-explanation-close-btn" class="question-explanation-close-btn" hidden aria-label="סגור הסבר">×</button>
            <video id="question-explanation-video" class="question-explanation-video" controls playsinline preload="metadata"></video>
        </div>
        <partial name="Shared/_QuestionExplanationRating" />
    </div>

    @if (Model.NewAchievements.Count > 0)
    {
        <div class="achievement-toast achievement-toast-inline">
            @foreach (var key in Model.NewAchievements)
            {
                var def = NoodlesSimulator.Models.AchievementCatalog.Find(key);
                if (def != null)
                {
                    <p class="achievement-toast-item">@def.Emoji הישג חדש: <strong>@def.Title</strong></p>
                }
            }
        </div>
    }

    <div class="button-row">
        @if (Model.HasMistakes)
        {
            <form method="get" action="/Index">
                <input type="hidden" name="mode" value="review" />
                <button class="next-question-btn">🔁 חזור על הטעויות</button>
            </form>
        }
        <form method="get" action="/Index">
            <button class="next-question-btn">חזרה לחידון</button>
        </form>
    </div>
</div>

<div id="image-modal" class="image-modal modal-hidden">
    <span class="close-modal" id="close-image-modal-btn">&times;</span>
    <img class="modal-content" id="modal-img" src="@(startItem?.QuestionUrl ?? "")" alt="שאלה מוגדלת" />
</div>

<div id="test-results-page-data"
     data-initial-index="@Model.InitialIndex"
     data-total="@Model.Total"></div>
<script type="application/json" id="test-results-items-json">@Html.Raw(Model.ItemsJson)</script>
<script src="/js/image-modal.js" asp-append-version="true"></script>
<script src="/js/quiz-viewport.js" asp-append-version="true"></script>
<script src="/js/question-explanation.js" asp-append-version="true"></script>
<script src="/js/test-results-page.js" asp-append-version="true"></script>

<partial name="Shared/_SiteFooter" />
</body>
</html>
