@page
@model NoodlesSimulator.Pages.TestResultsModel
@{
    ViewData["Title"] = "סיכום מבחן";
}

<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — Test Summary</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo/noodles-logo-transparent.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/logo/noodles-logo-transparent.png">
    <link rel="apple-touch-icon" sizes="192x192" href="/logo/noodles-logo-transparent.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#222222">
    <meta name="robots" content="noindex">
}</head>

<img src="/assets/background.gif" alt="רקע" class="background-gif" />

<partial name="Shared/_TopBar" />
<partial name="Shared/_LogoHeader" />

<div class="quiz-container">
    <h2 class="test-results-title">סיכום מבחן</h2>
    <p class="test-results-summary">
        ניקוד: <strong>@Model.Score</strong> מתוך @Model.MaxScore
        · נכונות: <strong>@Model.CorrectCount</strong> / @Model.Total
        · זמן: <strong>@Model.ElapsedText</strong>
    </p>

    <div class="test-results-list">
        @for (int i = 0; i < Model.Items.Count; i++)
        {
            var item = Model.Items[i];
            <div class="test-results-item">
                <a href="@(string.IsNullOrWhiteSpace(Model.ReviewToken) ? $"/TestReview?i={i}" : $"/TestReview?token={Uri.EscapeDataString(Model.ReviewToken)}&i={i}")" title="הצג סקירה"
                   class="test-results-review-link">
                    🔍
                </a>
                <img src="@item.QuestionUrl" alt="שאלה @(i+1)" class="test-results-question-image" />
                <div class="test-results-item-content">
                    <div class="test-results-item-title @(item.IsCorrect ? "test-results-item-title-correct" : "test-results-item-title-incorrect")">
                        שאלה @(i+1) — @(item.IsCorrect ? "נכון" : "לא נכון")
                    </div>
                    <div class="test-results-answers">
                        @if (!string.IsNullOrWhiteSpace(item.SelectedUrl))
                        {
                            <div>
                                <div class="test-results-answer-label">התשובה שנענתה</div>
                                <img src="@item.SelectedUrl" alt="נענתה" class="result-ans" />
                            </div>
                        }
                        <div>
                            <div class="test-results-answer-label">התשובה הנכונה</div>
                            <img src="@item.CorrectUrl" alt="נכונה" class="result-ans" />
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="button-row">
        <form method="get" action="/Index">
            <button class="next-question-btn">חזרה לחידון</button>
        </form>
    </div>
</div>

<partial name="Shared/_SiteFooter" />
