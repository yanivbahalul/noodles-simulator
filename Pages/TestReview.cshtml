@page
@model NoodlesSimulator.Pages.TestReviewModel
@{
    ViewData["Title"] = "סקירת שאלה";
}

<head>
    <meta charset="utf-8" />
    <title>Noodles Simulator — Test Review</title>
    <link rel="stylesheet" href="/css/site.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex">
}</head>

<img src="/assets/background.gif" alt="רקע" class="background-gif" />

<partial name="Shared/_LogoHeader" />

<div class="quiz-container">
    @if (!string.IsNullOrWhiteSpace(Model.QuestionImageUrl))
    {
        <img src="@Model.QuestionImageUrl" alt="שאלה" loading="lazy" id="main-question-image" class="review-main-question-image" />
    }

    <div class="answers">
        @foreach (var kv in Model.AnswerImageUrls)
        {
            var key = kv.Key;
            var url = kv.Value;
            var cls = (key == "correct") ? "correct" : (Model.SelectedKey == key ? "incorrect" : "");
            <button class="answer-btn @cls" disabled>
                <img src="@url" alt="תשובה" loading="lazy" />
            </button>
        }
    </div>

    <div class="button-row">
        <form method="get" action="/TestResults">
            @if (!string.IsNullOrWhiteSpace(Model.ReviewToken))
            {
                <input type="hidden" name="token" value="@Model.ReviewToken" />
            }
            <button class="next-question-btn">חזרה לסיכום</button>
        </form>
    </div>
</div>

<!-- Image Modal -->
<div id="image-modal" class="image-modal modal-hidden">
    <span class="close-modal" id="close-image-modal-btn">&times;</span>
    <img class="modal-content" id="modal-img" src="@Model.QuestionImageUrl" alt="שאלה מוגדלת" />
</div>

<div id="test-review-data" data-question-image-url="@Model.QuestionImageUrl"></div>
<script src="/js/testreview-page.js"></script>

<partial name="Shared/_SiteFooter" />

