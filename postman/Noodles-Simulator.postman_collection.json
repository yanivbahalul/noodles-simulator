{
  "info": {
    "name": "Noodles Simulator",
    "description": "Public APIs, Supabase REST, and health checks for noodles-simulator.up.railway.app.\n\nImport with Noodles-Simulator.postman_environment.json and set secret keys there.\nAuthenticated Razor Page handlers need a session cookie — use Postman after manual login or Newman with cookie jar.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{base_url}}" }
  ],
  "item": [
    {
      "name": "Public APIs",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('ok true', () => pm.expect(j.ok).to.eql(true));",
                  "['supabaseUrl','supabaseAnon','supabaseService','supabaseBucket'].forEach(k => {",
                  "  pm.test('health.' + k, () => pm.expect(j[k]).to.eql('ok'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Online count",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/online-count"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Leaderboard (total)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/leaderboard-data?tab=total",
              "host": ["{{base_url}}"],
              "path": ["api", "leaderboard-data"],
              "query": [{ "key": "tab", "value": "total" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Leaderboard (level)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/leaderboard-data?tab=level",
              "host": ["{{base_url}}"],
              "path": ["api", "leaderboard-data"],
              "query": [{ "key": "tab", "value": "level" }]
            }
          }
        },
        {
          "name": "Leaderboard (weekly)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/leaderboard-data?tab=weekly",
              "host": ["{{base_url}}"],
              "path": ["api", "leaderboard-data"],
              "query": [{ "key": "tab", "value": "weekly" }]
            }
          }
        },
        {
          "name": "Leaderboard (achievement)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/leaderboard-data?tab=achievement",
              "host": ["{{base_url}}"],
              "path": ["api", "leaderboard-data"],
              "query": [{ "key": "tab", "value": "achievement" }]
            }
          }
        },
        {
          "name": "Question difficulty",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/question-difficulty"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login page",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/Login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('has CSRF token', () => pm.expect(pm.response.text()).to.match(/__RequestVerificationToken/));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Leaderboard page",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/Leaderboard"
          }
        }
      ]
    },
    {
      "name": "Authenticated (session cookie)",
      "description": "Requires .Noodles.Session cookie after POST /Login. Run Login page first, then POST login from browser or use post-deploy-verify.py.",
      "item": [
        {
          "name": "Stats data",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/stats-data"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200 or 401', () => pm.expect(pm.response.code).to.be.oneOf([200, 401]));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Next question",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/Index?handler=NextQuestion",
              "host": ["{{base_url}}"],
              "path": ["Index"],
              "query": [{ "key": "handler", "value": "NextQuestion" }]
            }
          }
        },
        {
          "name": "Signed storage URL",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/signed?path=example.png",
              "host": ["{{base_url}}"],
              "path": ["signed"],
              "query": [{ "key": "path", "value": "example.png" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin (session + IsAdmin)",
      "item": [
        {
          "name": "Dashboard data",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/dashboard-data"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('protected', () => pm.expect(pm.response.code).to.be.oneOf([401, 403, 302]));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Dashboard activity",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/dashboard-activity"
          }
        },
        {
          "name": "System check page",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/SystemCheck"
          }
        }
      ]
    },
    {
      "name": "Supabase REST",
      "item": [
        {
          "name": "user_stats (count)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_service_key}}" },
              { "key": "Authorization", "value": "Bearer {{supabase_service_key}}" },
              { "key": "Prefer", "value": "count=exact" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/user_stats?select=*&limit=1",
              "host": ["{{supabase_url}}"],
              "path": ["rest", "v1", "user_stats"],
              "query": [
                { "key": "select", "value": "*" },
                { "key": "limit", "value": "1" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200 or 206', () => pm.expect(pm.response.code).to.be.oneOf([200, 206]));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "user_question_stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_service_key}}" },
              { "key": "Authorization", "value": "Bearer {{supabase_service_key}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/user_question_stats?select=*&limit=1"
          }
        },
        {
          "name": "user_progress",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_service_key}}" },
              { "key": "Authorization", "value": "Bearer {{supabase_service_key}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/user_progress?select=*&limit=1"
          }
        },
        {
          "name": "user_achievements",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_service_key}}" },
              { "key": "Authorization", "value": "Bearer {{supabase_service_key}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/user_achievements?select=*&limit=1"
          }
        },
        {
          "name": "test_sessions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_service_key}}" },
              { "key": "Authorization", "value": "Bearer {{supabase_service_key}}" }
            ],
            "url": "{{supabase_url}}/rest/v1/test_sessions?select=*&limit=1"
          }
        }
      ]
    }
  ]
}
